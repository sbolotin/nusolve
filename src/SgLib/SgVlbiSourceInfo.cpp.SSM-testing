//
double SgVlbiSourceInfo::arcLength(double ra_1, double dn_1, double ra_2, double dn_2)
{
  long double                   sdn1=0.0, cdn1=0.0, sdn2=0.0, cdn2=0.0;
  long double                   cdra=0.0;
  
  if (abs(ra_1-ra_2)<20.0/RAD2MAS && abs(dn_1-dn_2)<20.0/RAD2MAS) // almost linear 
    return sqrt((ra_1-ra_2)*(ra_1-ra_2)*cos(dn_1)*cos(dn_1) + (dn_1-dn_2)*(dn_1-dn_2));

  // calculate arc-length:
  sincosl(dn_1, &sdn1, &cdn1);
  sincosl(dn_2, &sdn2, &cdn2);
  cdra = cosl(ra_1 - ra_2);
  return acosl(sdn1*sdn2 + cdn1*cdn2*cdra);
};



//
QString SgVlbiSourceInfo::ra2String(double ra)
{
  QString     str;
  int         nHour, nMin;
  double      dSec, dTmp;

  dTmp = ra*RAD2MS;
  nHour = (int)(dTmp/3600.0/1000.0);
  nMin  = (int)((dTmp - 3600.0*1000.0*nHour)/60.0/1000.0);
  dSec  = (dTmp - 3600.0*1000.0*nHour - 60.0*1000.0*nMin)/1000.0;
  
  str.sprintf("%02d %02d %011.8f", nHour, nMin, dSec);

  return str;
};



//
QString SgVlbiSourceInfo::dn2String(double dn, bool mandatorySign)
{
  QString     str;
  int         nDeg, nMin;
  double      dSec, dTmp;
  char        cSign=mandatorySign?'+':' ';
  if (dn<0.0)
  {
    dn = -dn;
    cSign = '-';
  };

  dTmp = dn*RAD2MAS;
  nDeg = (int)(dTmp/3600/1000.0);
  nMin = (int)((dTmp - 3600.0*1000.0*nDeg)/60.0/1000.0);
  dSec = (dTmp - 3600.0*1000.0*nDeg - 60.0*1000.0*nMin)/1000.0;
  
  str.sprintf("%c%02d %02d %011.8f", cSign, nDeg, nMin, dSec);

  return str;
};



//
void SgVlbiSourceInfo::createParameters()
{
  QString prefix = "Src " + getKey().leftJustified(8, ' ') + ": ";
  releaseParameters();
  pRA_ = new SgParameter(prefix + "RA");
  pDN_ = new SgParameter(prefix + "DN");

  pK_  = new SgParameter(prefix + "ssK");
  pB_  = new SgParameter(prefix + "ssB");
  pX_  = new SgParameter(prefix + "ssX");
  pY_  = new SgParameter(prefix + "ssY");

  pA0_ = new SgParameter(prefix + "ssA0");
  pB0_ = new SgParameter(prefix + "ssB0");
  pTheta0_ = new SgParameter(prefix + "ssTheta0");
  pA1_ = new SgParameter(prefix + "ssA1");
  pB1_ = new SgParameter(prefix + "ssB1");
  pTheta1_ = new SgParameter(prefix + "ssTheta1");


  for (int i=0; i<sModel_.size(); i++)
  {
    sModel_[i].pK() = new SgParameter(prefix + "k_" + QString("").sprintf("%03d", i));
    sModel_[i].pB() = new SgParameter(prefix + "b_" + QString("").sprintf("%03d", i));
    sModel_[i].pX() = new SgParameter(prefix + "x_" + QString("").sprintf("%03d", i));
    sModel_[i].pY() = new SgParameter(prefix + "y_" + QString("").sprintf("%03d", i));
  };

};



//
void SgVlbiSourceInfo::releaseParameters()
{
  if (pRA_)
  {
    delete pRA_;
    pRA_ = NULL;
  };
  if (pDN_)
  {
    delete pDN_;
    pDN_ = NULL;
  };
  for (int i=0; i<sModel_.size(); i++)
  {
    if (sModel_[i].pK())
    {
      delete sModel_[i].pK();
      sModel_[i].pK() = NULL;
    };
    if (sModel_[i].pB())
    {
      delete sModel_[i].pB();
      sModel_[i].pB() = NULL;
    };
    if (sModel_[i].pX())
    {
      delete sModel_[i].pX();
      sModel_[i].pX() = NULL;
    };
    if (sModel_[i].pY())
    {
      delete sModel_[i].pY();
      sModel_[i].pY() = NULL;
    };
  };


  if (pK_)
  {
    delete pK_;
    pK_ = NULL;
  };
  if (pB_)
  {
    delete pB_;
    pB_ = NULL;
  };
  if (pX_)
  {
    delete pX_;
    pX_ = NULL;
  };
  if (pY_)
  {
    delete pY_;
    pY_ = NULL;
  };


  if (pA0_)
  {
    delete pA0_;
    pA0_ = NULL;
  };
  if (pB0_)
  {
    delete pB0_;
    pB0_ = NULL;
  };
  if (pTheta0_)
  {
    delete pTheta0_;
    pTheta0_ = NULL;
  };
  if (pA1_)
  {
    delete pA1_;
    pA1_ = NULL;
  };
  if (pB1_)
  {
    delete pB1_;
    pB1_ = NULL;
  };
  if (pTheta1_)
  {
    delete pTheta1_;
    pTheta1_ = NULL;
  };

 
};



//
bool SgVlbiSourceInfo::saveIntermediateResults(QDataStream& s) const
{
  SgObjectInfo::saveIntermediateResults(s);
  return s.status() == QDataStream::Ok;
};



//
bool SgVlbiSourceInfo::loadIntermediateResults(QDataStream& s)
{
  SgObjectInfo::loadIntermediateResults(s);
  return s.status()==QDataStream::Ok;
};



//
double SgVlbiSourceInfo::calcR(double u, double v)
{
  return u*x_ + v*y_;
};



//
double SgVlbiSourceInfo::tauS(double f, double u, double v)
{
  double                        d=0.0;
  if (smtType_ == SMT_NONE)
    return d;
  else if (smtType_ == SMT_TWO_POINTS)
  {

    if (isExtSS_) // with shape (4tests)
    {
      double                      r, c, s, dQ, dT1, dT2, dA, dB;
      double                      st0, ct0, st1, ct1;
      double                      u0, v0, u1, v1;
      r = calcR(u, v);
      sincos(2.0*M_PI*r, &s, &c);
      sincos(theta0_, &st0, &ct0);
      sincos(theta1_, &st1, &ct1);
      u0 = u*ct0 + v*st0;
      v0 =-u*st0 + v*ct0;
      u1 = u*ct1 + v*st1;
      v1 =-u*st1 + v*ct1;
      
      dA = 2.0*M_PI*a0_*b0_*exp(-2.0*M_PI*M_PI*(u0*u0*a0_*a0_ + v0*v0*b0_*b0_));
      dB = 2.0*M_PI*a1_*b1_*exp(-2.0*M_PI*M_PI*(u1*u1*a1_*a1_ + v1*v1*b1_*b1_));
      
      dT1 = -dA*dB*b_*k_*s/(2.0*M_PI*f);
      dT2 = -k_*r*dB*(k_*dB + dA*c)/f;
      dQ = dA*dA + k_*k_*dB*dB + 2.0*k_*dA*dB*c;

      // 1):
      d += dT1/dQ;
      // 2):
      d += dT2/dQ;
    }
    else
    {
      double                      r, c, s, a;
      r = calcR(u, v);
      sincos(2.0*M_PI*r, &s, &c);
      a = k_*k_ + 2.0*k_*c + 1.0;

      // 1):
      d += - b_*k_*s/(2.0*M_PI*f)/a;
      // 2):
      d += - k_*r*(k_ + c)/f/a;
    };
  }
  else if (smtType_ == SMT_MULTIPLE_POINTS)
  {
    if (!sModel_.size())
      return d;
    
    if (isExtSS_) // with sp.idx:
    {
      double              dT1, dT2, dQ;
      double              s1, s2, s3, s4, s5;
      double              ss1, ss2, ss3;
      int                 n=sModel_.size();
      s1 = s2 = s3 = s4 = s5 = ss1 = ss2 = ss3 = 0.0;
      
      for (int i=0; i<n; i++)
      {
        sModel_[i].prepareModel(u, v);
        s1 += sModel_.at(i).getB()*sModel_.at(i).getK()*sModel_.at(i).getS();
        s2 += sModel_.at(i).getK()*sModel_.at(i).getR()*sModel_.at(i).getC();
        s3 += sModel_.at(i).getK()*sModel_.at(i).getK()*sModel_.at(i).getR();
        s4 += sModel_.at(i).getK()*sModel_.at(i).getK();
        s5 += sModel_.at(i).getK()*sModel_.at(i).getC();
      };
      
      for (int i=0; i<n-1; i++)
        for (int j=i+1; j<n; j++)
        {
          double                sPhi_ij, cPhi_ij;
          sincos(2.0*M_PI*(sModel_.at(i).getR() - sModel_.at(j).getR()),    &sPhi_ij, &cPhi_ij);

          ss1 += sModel_.at(i).getK()*sModel_.at(j).getK()*
                      (sModel_.at(i).getB() - sModel_.at(j).getB())*sPhi_ij;
            
          ss2 += sModel_.at(i).getK()*sModel_.at(j).getK()*
                      (sModel_.at(i).getR() + sModel_.at(j).getR())*cPhi_ij;
          
          ss3 += sModel_.at(i).getK()*sModel_.at(j).getK()*cPhi_ij;
        };

      dT1 = -1.0/(2.0*M_PI*f)*(s1 + ss1);
      dT2 = -1.0/f*(s2 + s3 + ss2);
      dQ  = 1.0 + s4 + 2.0*(s5 + ss3);
      
      d = (dT1 + dT2)/dQ;
    }
    else // no sp idx:
    {
      double                    dA, dB, dC, dD, dQ;
      dA = dB = dC = dD = dQ = 0.0;
      for (int i=0; i<sModel_.size(); i++)
      {
        sModel_[i].prepareModel(u, v);
        dA += sModel_.at(i).getK()*sModel_.at(i).getS();
        dB += sModel_.at(i).getK()*sModel_.at(i).getC();
        dC += sModel_.at(i).getK()*sModel_.at(i).getR()*sModel_.at(i).getS();
        dD += sModel_.at(i).getK()*sModel_.at(i).getR()*sModel_.at(i).getC();
      };
      dQ = 1.0 + dA*dA + dB*dB + 2.0*dB;
      d = -1.0/f*(dA*dC + (dB + 1.0)*dD)/dQ;
    };

  }
  else
  {
  
  };
  
  return d;
};



//
void SgVlbiSourceInfo::processPartials4SrcStructModel(QList<SgParameter*>& parameters,
  double f, double u, double v)
{
  if (!sModel_.size())
    return;


  if (isExtSS_) // with sp.idx:
  {

    double              dT1, dT2, dQ;
    double              s1, s2, s3, s4, s5;
    double              ss1, ss2, ss3;
    int                 n=sModel_.size();
    s1 = s2 = s3 = s4 = s5 = ss1 = ss2 = ss3 = 0.0;
    for (int i=0; i<n; i++)
    {
      sModel_[i].prepareModel(u, v);
      s1 += sModel_.at(i).getB()*sModel_.at(i).getK()*sModel_.at(i).getS();
      s2 += sModel_.at(i).getK()*sModel_.at(i).getR()*sModel_.at(i).getC();
      s3 += sModel_.at(i).getK()*sModel_.at(i).getK()*sModel_.at(i).getR();
      s4 += sModel_.at(i).getK()*sModel_.at(i).getK();
      s5 += sModel_.at(i).getK()*sModel_.at(i).getC();
    };
      
    for (int i=0; i<n-1; i++)
      for (int j=i+1; j<n; j++)
      {
        double                sPhi_ij, cPhi_ij;
        sincos(2.0*M_PI*(sModel_.at(i).getR() - sModel_.at(j).getR()),    &sPhi_ij, &cPhi_ij);

        ss1 += sModel_.at(i).getK()*sModel_.at(j).getK()*
                    (sModel_.at(i).getB() - sModel_.at(j).getB())*sPhi_ij;
            
        ss2 += sModel_.at(i).getK()*sModel_.at(j).getK()*
                    (sModel_.at(i).getR() + sModel_.at(j).getR())*cPhi_ij;
          
        ss3 += sModel_.at(i).getK()*sModel_.at(j).getK()*cPhi_ij;
      };

    dT1 = -1.0/(2.0*M_PI*f)*(s1 + ss1);
    dT2 = -1.0/f*(s2 + s3 + ss2);
    dQ  = 1.0 + s4 + 2.0*(s5 + ss3);
      

    for (int l=0; l<n; l++)
    {
      double                    dCl=sModel_.at(l).getC();
      double                    dSl=sModel_.at(l).getS();
      double                    dRl=sModel_.at(l).getR();
      double                    dKl=sModel_.at(l).getK();
      double                    dBl=sModel_.at(l).getB();
      double                    t1L, t1R, t2L, t2R, t3L, t3R, t4L, t4R, t5L, t5R, t6L, t6R;
      t1L = t1R = t2L = t2R = t3L = t3R = t4L = t4R = t5L = t5R = t6L = t6R = 0.0;

      double                    sPhi_il, cPhi_il;
      double                    sPhi_li, cPhi_li;
      
      // left part:
      for (int i=0; i<l; i++)
      {
        sincos(2.0*M_PI*(sModel_.at(i).getR() - sModel_.at(l).getR()),    &sPhi_il, &cPhi_il);
        sPhi_li =-sPhi_il;
        cPhi_li = cPhi_il;

        t1L = sModel_.at(i).getK()*sPhi_il;
        t2L = sModel_.at(i).getK()*(sModel_.at(i).getB() - sModel_.at(l).getB())*sPhi_il;
        t3L = sModel_.at(i).getK()*(sModel_.at(i).getR() + sModel_.at(l).getR())*cPhi_il;
        t4L = sModel_.at(i).getK()*cPhi_il;
        t5L = sModel_.at(i).getK()*(sModel_.at(i).getB() - sModel_.at(l).getB())*cPhi_il;
        t6L = sModel_.at(i).getK()*(sModel_.at(i).getR() + sModel_.at(l).getR())*sPhi_il;
      };
      // right part:
      for (int i=l+1; i<n; i++)
      {
        sincos(2.0*M_PI*(sModel_.at(i).getR() - sModel_.at(l).getR()),    &sPhi_il, &cPhi_il);
        sPhi_li =-sPhi_il;
        cPhi_li = cPhi_il;
        
        t1R = sModel_.at(i).getK()*sPhi_li;
        t2R = sModel_.at(i).getK()*(sModel_.at(l).getB() - sModel_.at(i).getB())*sPhi_li;
        t3R = sModel_.at(i).getK()*(sModel_.at(l).getR() + sModel_.at(i).getR())*cPhi_li;
        t4R = sModel_.at(i).getK()*cPhi_li;
        t5R = sModel_.at(i).getK()*(sModel_.at(l).getB() - sModel_.at(i).getB())*cPhi_li;
        t6R = sModel_.at(i).getK()*(sModel_.at(l).getR() + sModel_.at(i).getR())*sPhi_li;
      };
      double                    dTau1_dBl, dTau1_dKl, dTau2_dKl, dQ_dKl, dTau1_dRl, dTau2_dRl, dQ_dRl;

      dTau1_dBl = -dKl/(2.0*M_PI*f)*(dSl - t1L + t1R);
      
      dTau1_dKl = -1.0/(2.0*M_PI*f)*(dBl*dSl + t2L + t2R);
      dTau2_dKl = -1.0/f*(dRl*(dCl + 2.0*dKl) + t3L + t3R);
      dQ_dKl    = 2.0*(dKl + dCl + t4L + t4R);
      
      dTau1_dRl = -dKl/f*(dBl*dCl - t5L + t5R);
      dTau2_dRl = -dKl/f*(dCl + dKl - 2.0*M_PI*dRl*dSl + t4L + t4R + 2.0*M_PI*(t6L - t6R));
      dQ_dRl    = -4.0*M_PI*dKl*(dSl - t1L + t1R);

      double                    d;
      if (sModel_[l].pK()->isAttr(SgPartial::Attr_IS_IN_RUN))
      {
        d = (dTau1_dKl + dTau2_dKl)/dQ - (dT1 + dT2)*dQ_dKl/dQ/dQ;
        sModel_[l].pK()->setD(d);
        parameters.append(sModel_[l].pK());
      };
      if (sModel_[l].pB()->isAttr(SgPartial::Attr_IS_IN_RUN))
      {
        d = dTau1_dBl/dQ;
        sModel_[l].pB()->setD(d);
        parameters.append(sModel_[l].pB());
      };

      if (sModel_[l].pX()->isAttr(SgPartial::Attr_IS_IN_RUN))
      {
        d = (dTau1_dRl + dTau2_dRl)/dQ - (dT1 + dT2)*dQ_dRl/dQ/dQ;
        sModel_[l].pX()->setD(d*u);
        sModel_[l].pY()->setD(d*v);
        parameters.append(sModel_[l].pX());
        parameters.append(sModel_[l].pY());
      };
    };


  
  }
  else // no sp idx:
  {


    double                        d, dA, dB, dC, dD, dQ;
    dA = dB = dC = dD = dQ = 0.0;
    for (int i=0; i<sModel_.size(); i++)
    {
      sModel_[i].prepareModel(u, v);
      dA += sModel_.at(i).getK()*sModel_.at(i).getS();
      dB += sModel_.at(i).getK()*sModel_.at(i).getC();
      dC += sModel_.at(i).getK()*sModel_.at(i).getR()*sModel_.at(i).getS();
      dD += sModel_.at(i).getK()*sModel_.at(i).getR()*sModel_.at(i).getC();
    };
    dQ = 1.0 + dA*dA + dB*dB + 2.0*dB;

    for (int j=0; j<sModel_.size(); j++)
    {
      double                      dCj=sModel_.at(j).getC();
      double                      dSj=sModel_.at(j).getS();
      double                      dRj=sModel_.at(j).getR();
      double                      dKj=sModel_.at(j).getK();

      if (sModel_[j].pK()->isAttr(SgPartial::Attr_IS_IN_RUN))
      {
        d = -1.0/f/dQ*
          (dSj*(dC + dRj*dA) + dCj*(dD + dRj*(dB + 1.0)) - 
            2.0*(dA*dC + (dB + 1.0)*dD)*(dSj*dA + dCj*(dB + 1.0))/dQ);
        sModel_[j].pK()->setD(d);
        parameters.append(sModel_[j].pK());
      };
      if (sModel_[j].pX()->isAttr(SgPartial::Attr_IS_IN_RUN))
      {
        d = -dKj/f/dQ*
          (2.0*M_PI*(dCj*dC - dSj*dD) + (dSj + 2.0*M_PI*dRj*dCj)*dA + (dCj - 2.0*M_PI*dRj*dSj)*(dB + 1) -
            4.0*M_PI*(dA*dC + dD*(dB + 1.0))/dQ*(dCj*dA - dSj*(dB + 1)));
      
        sModel_[j].pX()->setD(d*u);
        sModel_[j].pY()->setD(d*v);
        parameters.append(sModel_[j].pX());
        parameters.append(sModel_[j].pY());
      };
    };


  };
};



//
double SgVlbiSourceInfo::dTauS_dK(double f, double u, double v)
{
  double                        d=0.0;
  double                        r, c, s, dQ;
  
  r = calcR(u, v);
  sincos(2.0*M_PI*r, &s, &c);

  if (isExtSS_) // with shape (4tests)
  {
    double                      dT1, dT2, dA, dB;
    double                      st0, ct0, st1, ct1;
    double                      u0, v0, u1, v1;
    r = calcR(u, v);
    sincos(2.0*M_PI*r, &s, &c);
    sincos(theta0_, &st0, &ct0);
    sincos(theta1_, &st1, &ct1);
    u0 = u*ct0 + v*st0;
    v0 =-u*st0 + v*ct0;
    u1 = u*ct1 + v*st1;
    v1 =-u*st1 + v*ct1;
      
    dA = 2.0*M_PI*a0_*b0_*exp(-2.0*M_PI*M_PI*(u0*u0*a0_*a0_ + v0*v0*b0_*b0_));
    dB = 2.0*M_PI*a1_*b1_*exp(-2.0*M_PI*M_PI*(u1*u1*a1_*a1_ + v1*v1*b1_*b1_));
      
    dT1 = -dA*dB*b_*k_*s/(2.0*M_PI*f);
    dT2 = -k_*r*dB*(k_*dB + dA*c)/f;
    dQ = dA*dA + k_*k_*dB*dB + 2.0*k_*dA*dB*c;

    double                      dQ_dK, dT1_dK, dT2_dK;

    dQ_dK   = 2.0*dB*(k_*dB + dA*c);
    dT1_dK  = -dA*dB*b_*s/(2.0*M_PI*f);
//  dT2_dK  = -2.0*dB*r*(k_*dB + dA*c)/f;
    dT2_dK  = -dB*r*(2.0*k_*dB + dA*c)/f;

    d = (dT1_dK + dT2_dK)/dQ - (dT1 + dT2)*dQ_dK/dQ/dQ;
  }
  else
  {
    dQ = k_*k_ + 2.0*k_*c + 1.0;

    // 1):
    d  = - b_*s*(1.0 - k_*k_)/(2.0*M_PI*f)/dQ/dQ;
    // 2):
    d += - r*(dQ*(2.0*k_ + c) - 2.0*k_*(k_ + c)*(k_ + c))/f/dQ/dQ;
  };
  return d;
};



//
//
double SgVlbiSourceInfo::dTauS_dB(double f, double u, double v)
{
  double                        d=0.0;
  double                        r, c, s, dQ;
  
  r = calcR(u, v);
  sincos(2.0*M_PI*r, &s, &c);

  if (isExtSS_) // with shape (4tests)
  {
    double                      dA, dB;
    double                      st0, ct0, st1, ct1;
    double                      u0, v0, u1, v1;
    sincos(theta0_, &st0, &ct0);
    sincos(theta1_, &st1, &ct1);
    u0 = u*ct0 + v*st0;
    v0 =-u*st0 + v*ct0;
    u1 = u*ct1 + v*st1;
    v1 =-u*st1 + v*ct1;
     
    dA = 2.0*M_PI*a0_*b0_*exp(-2.0*M_PI*M_PI*(u0*u0*a0_*a0_ + v0*v0*b0_*b0_));
    dB = 2.0*M_PI*a1_*b1_*exp(-2.0*M_PI*M_PI*(u1*u1*a1_*a1_ + v1*v1*b1_*b1_));
      
    dQ = dA*dA + k_*k_*dB*dB + 2.0*k_*dA*dB*c;

    d = -dA*dB*k_*s/(2.0*M_PI*f)/dQ;
  }
  else
  {
    dQ = k_*k_ + 2.0*k_*c + 1.0;
    // 1):
    d  = - k_*s/(2.0*M_PI*f)/dQ;
  };
   
  return d;
};



//
double SgVlbiSourceInfo::dTauS_dR(double f, double u, double v)
{
  double                        d=0.0;
  double                        r, c, s, dQ;

  if (isExtSS_) // with shape (4tests)
  {
    double                      dT1, dT2, dA, dB;
    double                      st0, ct0, st1, ct1;
    double                      u0, v0, u1, v1;
    r = calcR(u, v);
    sincos(2.0*M_PI*r, &s, &c);
    sincos(theta0_, &st0, &ct0);
    sincos(theta1_, &st1, &ct1);
    u0 = u*ct0 + v*st0;
    v0 =-u*st0 + v*ct0;
    u1 = u*ct1 + v*st1;
    v1 =-u*st1 + v*ct1;
      
    dA = 2.0*M_PI*a0_*b0_*exp(-2.0*M_PI*M_PI*(u0*u0*a0_*a0_ + v0*v0*b0_*b0_));
    dB = 2.0*M_PI*a1_*b1_*exp(-2.0*M_PI*M_PI*(u1*u1*a1_*a1_ + v1*v1*b1_*b1_));
      
    dT1 = -dA*dB*b_*k_*s/(2.0*M_PI*f);
    dT2 = -k_*r*dB*(k_*dB + dA*c)/f;
    dQ = dA*dA + k_*k_*dB*dB + 2.0*k_*dA*dB*c;

    double                      dQ_dR, dT1_dR, dT2_dR;

    dQ_dR   = -4.0*M_PI*dA*dB*k_*s;
    dT1_dR  = -dA*dB*b_*k_*c/f;
    dT2_dR  = -dB*k_*(k_*dB + dA*c - 2.0*M_PI*dA*r*s)/f;

    d = (dT1_dR + dT2_dR)/dQ - (dT1 + dT2)*dQ_dR/dQ/dQ;
  }
  else
  {
    r = calcR(u, v);

    sincos(2.0*M_PI*r, &s, &c);
    dQ = k_*k_ + 2.0*k_*c + 1.0;

    // 1):
    d  = - b_*k_*(dQ*c + 2.0*k_*s*s)/f/dQ/dQ;
    // 2):
    d += - k_*(dQ*(k_ + c - 2.0*M_PI*r*s) + 4.0*M_PI*k_*r*s*(k_ + c))/f/dQ/dQ;
  };
  return d;
};



//
double SgVlbiSourceInfo::dTauS_dX(double f, double u, double v)
{
  return dTauS_dR(f, u, v)*u;
};



//
double SgVlbiSourceInfo::dTauS_dY(double f, double u, double v)
{
  return dTauS_dR(f, u, v)*v;
};



//
double SgVlbiSourceInfo::dTauS_dA0(double f, double u, double v)
{
  double                          d=0.0;
  double                          r, c, s, dQ;

  double                          dT1, dT2, dA, dB;
  double                          st0, ct0, st1, ct1;
  double                          u0, v0, u1, v1;
  r = calcR(u, v);
  sincos(2.0*M_PI*r, &s, &c);
  sincos(theta0_, &st0, &ct0);
  sincos(theta1_, &st1, &ct1);
  u0 = u*ct0 + v*st0;
  v0 =-u*st0 + v*ct0;
  u1 = u*ct1 + v*st1;
  v1 =-u*st1 + v*ct1;
      
  dA = 2.0*M_PI*a0_*b0_*exp(-2.0*M_PI*M_PI*(u0*u0*a0_*a0_ + v0*v0*b0_*b0_));
  dB = 2.0*M_PI*a1_*b1_*exp(-2.0*M_PI*M_PI*(u1*u1*a1_*a1_ + v1*v1*b1_*b1_));
      
  dT1 = -dA*dB*b_*k_*s/(2.0*M_PI*f);
  dT2 = -k_*r*dB*(k_*dB + dA*c)/f;
  dQ = dA*dA + k_*k_*dB*dB + 2.0*k_*dA*dB*c;

  double                          dQ_dp, dT1_dp, dT2_dp;
  double                          q;
  q = (1.0 - 4.0*M_PI*M_PI*u0*u0*a0_*a0_)/a0_;

  dQ_dp   = 2.0*dA*(dA + 2.0*k_*dB*c)*q;
  dT1_dp  = -dA*dB/(2.0*M_PI*f)*b_*k_*s*q;
  dT2_dp  = -dA*dB/f*k_*r*c*q;

  d = (dT1_dp + dT2_dp)/dQ - (dT1 + dT2)*dQ_dp/dQ/dQ;
  
  return d;
};



//
double SgVlbiSourceInfo::dTauS_dB0(double f, double u, double v)
{
  double                          d=0.0;
  double                          r, c, s, dQ;

  double                          dT1, dT2, dA, dB;
  double                          st0, ct0, st1, ct1;
  double                          u0, v0, u1, v1;
  r = calcR(u, v);
  sincos(2.0*M_PI*r, &s, &c);
  sincos(theta0_, &st0, &ct0);
  sincos(theta1_, &st1, &ct1);
  u0 = u*ct0 + v*st0;
  v0 =-u*st0 + v*ct0;
  u1 = u*ct1 + v*st1;
  v1 =-u*st1 + v*ct1;
      
  dA = 2.0*M_PI*a0_*b0_*exp(-2.0*M_PI*M_PI*(u0*u0*a0_*a0_ + v0*v0*b0_*b0_));
  dB = 2.0*M_PI*a1_*b1_*exp(-2.0*M_PI*M_PI*(u1*u1*a1_*a1_ + v1*v1*b1_*b1_));
      
  dT1 = -dA*dB*b_*k_*s/(2.0*M_PI*f);
  dT2 = -k_*r*dB*(k_*dB + dA*c)/f;
  dQ = dA*dA + k_*k_*dB*dB + 2.0*k_*dA*dB*c;

  double                          dQ_dp, dT1_dp, dT2_dp;
  double                          q;
  q = (1.0 - 4.0*M_PI*M_PI*v0*v0*b0_*b0_)/b0_;

  dQ_dp   = 2.0*dA*(dA + k_*dB*c)*q;
  dT1_dp  = -dA*dB/(2.0*M_PI*f)*b_*k_*s*q;
  dT2_dp  = -dA*dB/f*k_*r*c*q;

  d = (dT1_dp + dT2_dp)/dQ - (dT1 + dT2)*dQ_dp/dQ/dQ;

  return d;
};



//
double SgVlbiSourceInfo::dTauS_dTheta0(double f, double u, double v)
{
  double                          d=0.0;
  double                          r, c, s, dQ;

  double                          dT1, dT2, dA, dB;
  double                          st0, ct0, st1, ct1;
  double                          u0, v0, u1, v1;
  r = calcR(u, v);
  sincos(2.0*M_PI*r, &s, &c);
  sincos(theta0_, &st0, &ct0);
  sincos(theta1_, &st1, &ct1);
  u0 = u*ct0 + v*st0;
  v0 =-u*st0 + v*ct0;
  u1 = u*ct1 + v*st1;
  v1 =-u*st1 + v*ct1;
      
  dA = 2.0*M_PI*a0_*b0_*exp(-2.0*M_PI*M_PI*(u0*u0*a0_*a0_ + v0*v0*b0_*b0_));
  dB = 2.0*M_PI*a1_*b1_*exp(-2.0*M_PI*M_PI*(u1*u1*a1_*a1_ + v1*v1*b1_*b1_));
      
  dT1 = -dA*dB*b_*k_*s/(2.0*M_PI*f);
  dT2 = -k_*r*dB*(k_*dB + dA*c)/f;
  dQ = dA*dA + k_*k_*dB*dB + 2.0*k_*dA*dB*c;

  double                          dQ_dp, dT1_dp, dT2_dp;
  double                          du_dp, dv_dp, dC_dp;
  
  du_dp = -u*st0 + v*ct0;
  dv_dp = -u*ct0 - v*st0;
  dC_dp = -4.0*M_PI*M_PI*dA*(a0_*a0_*u0*du_dp + b0_*b0_*v0*dv_dp);
  
  dQ_dp   = 2.0*(dA + k_*dB*c)*dC_dp;
  dT1_dp  = -dB/(2.0*M_PI*f)*b_*k_*s*dC_dp;
  dT2_dp  = -dB/f*k_*r*c*dC_dp;

  d = (dT1_dp + dT2_dp)/dQ - (dT1 + dT2)*dQ_dp/dQ/dQ;

  return d;
};



//
double SgVlbiSourceInfo::dTauS_dA1(double f, double u, double v)
{
  double                          d=0.0;
  double                          r, c, s, dQ;

  double                          dT1, dT2, dA, dB;
  double                          st0, ct0, st1, ct1;
  double                          u0, v0, u1, v1;
  r = calcR(u, v);
  sincos(2.0*M_PI*r, &s, &c);
  sincos(theta0_, &st0, &ct0);
  sincos(theta1_, &st1, &ct1);
  u0 = u*ct0 + v*st0;
  v0 =-u*st0 + v*ct0;
  u1 = u*ct1 + v*st1;
  v1 =-u*st1 + v*ct1;
      
  dA = 2.0*M_PI*a0_*b0_*exp(-2.0*M_PI*M_PI*(u0*u0*a0_*a0_ + v0*v0*b0_*b0_));
  dB = 2.0*M_PI*a1_*b1_*exp(-2.0*M_PI*M_PI*(u1*u1*a1_*a1_ + v1*v1*b1_*b1_));
      
  dT1 = -dA*dB*b_*k_*s/(2.0*M_PI*f);
  dT2 = -k_*r*dB*(k_*dB + dA*c)/f;
  dQ = dA*dA + k_*k_*dB*dB + 2.0*k_*dA*dB*c;

  double                          dQ_dp, dT1_dp, dT2_dp;
  double                          q;
  q = (1.0 - 4.0*M_PI*M_PI*u1*u1*a1_*a1_)/a1_;

  dQ_dp   = 2.0*k_*dB*(k_*dB + dA*c)*q;
  dT1_dp  = -dA*dB/(2.0*M_PI*f)*b_*k_*s*q;
  dT2_dp  = -dB/f*k_*r*(2.0*k_*dB + dA*c)*q;

  d = (dT1_dp + dT2_dp)/dQ - (dT1 + dT2)*dQ_dp/dQ/dQ;
  
  return d;
};



//
double SgVlbiSourceInfo::dTauS_dB1(double f, double u, double v)
{
  double                          d=0.0;
  double                          r, c, s, dQ;

  double                          dT1, dT2, dA, dB;
  double                          st0, ct0, st1, ct1;
  double                          u0, v0, u1, v1;
  r = calcR(u, v);
  sincos(2.0*M_PI*r, &s, &c);
  sincos(theta0_, &st0, &ct0);
  sincos(theta1_, &st1, &ct1);
  u0 = u*ct0 + v*st0;
  v0 =-u*st0 + v*ct0;
  u1 = u*ct1 + v*st1;
  v1 =-u*st1 + v*ct1;
      
  dA = 2.0*M_PI*a0_*b0_*exp(-2.0*M_PI*M_PI*(u0*u0*a0_*a0_ + v0*v0*b0_*b0_));
  dB = 2.0*M_PI*a1_*b1_*exp(-2.0*M_PI*M_PI*(u1*u1*a1_*a1_ + v1*v1*b1_*b1_));
      
  dT1 = -dA*dB*b_*k_*s/(2.0*M_PI*f);
  dT2 = -k_*r*dB*(k_*dB + dA*c)/f;
  dQ = dA*dA + k_*k_*dB*dB + 2.0*k_*dA*dB*c;

  double                          dQ_dp, dT1_dp, dT2_dp;
  double                          q;
  q = (1.0 - 4.0*M_PI*M_PI*v1*v1*b1_*b1_)/b1_;

  dQ_dp   = 2.0*k_*dB*(k_*dB + dA*c)*q;
  dT1_dp  = -dA*dB/(2.0*M_PI*f)*b_*k_*s*q;
  dT2_dp  = -dB/f*k_*r*(2.0*k_*dB + dA*c)*q;

  d = (dT1_dp + dT2_dp)/dQ - (dT1 + dT2)*dQ_dp/dQ/dQ;
  
  return d;
};



//
double SgVlbiSourceInfo::dTauS_dTheta1(double f, double u, double v)
{
  double                          d=0.0;
  double                          r, c, s, dQ;

  double                          dT1, dT2, dA, dB;
  double                          st0, ct0, st1, ct1;
  double                          u0, v0, u1, v1;
  r = calcR(u, v);
  sincos(2.0*M_PI*r, &s, &c);
  sincos(theta0_, &st0, &ct0);
  sincos(theta1_, &st1, &ct1);
  u0 = u*ct0 + v*st0;
  v0 =-u*st0 + v*ct0;
  u1 = u*ct1 + v*st1;
  v1 =-u*st1 + v*ct1;
      
  dA = 2.0*M_PI*a0_*b0_*exp(-2.0*M_PI*M_PI*(u0*u0*a0_*a0_ + v0*v0*b0_*b0_));
  dB = 2.0*M_PI*a1_*b1_*exp(-2.0*M_PI*M_PI*(u1*u1*a1_*a1_ + v1*v1*b1_*b1_));
      
  dT1 = -dA*dB*b_*k_*s/(2.0*M_PI*f);
  dT2 = -k_*r*dB*(k_*dB + dA*c)/f;
  dQ = dA*dA + k_*k_*dB*dB + 2.0*k_*dA*dB*c;

  double                          dQ_dp, dT1_dp, dT2_dp;
  double                          du_dp, dv_dp, dC_dp;
  
  du_dp = -u*st1 + v*ct1;
  dv_dp = -u*ct1 - v*st1;
  dC_dp = -4.0*M_PI*M_PI*dB*(a1_*a1_*u1*du_dp + b1_*b1_*v1*dv_dp);
  
  dQ_dp   = 2.0*k_*(k_*dB + dA*c)*dC_dp;
  dT1_dp  = -dA/(2.0*M_PI*f)*b_*k_*s*dC_dp;
  dT2_dp  = -k_*r/f*(2.0*k_*dB + dA*c)*dC_dp;

  d = (dT1_dp + dT2_dp)/dQ - (dT1 + dT2)*dQ_dp/dQ/dQ;

  return d;
};



//
short SgVlbiSourceInfo::calculateStatusBits()
{
  short                         bitArray;
  bitArray = 0;
  //
  //  ! *                                                                      *
  //  ! *   Format of SOURSTAT_I2 array:                                       *
  //  ! *          Array SOURSTAT_I2  contains NUMSTR elements, where NUMSTR   *
  //  ! *               is the number of sources in database.                  *
  //  ! *          Each element of the array is 16-bits bit field. I-th element*
  //  ! *               of SOURSTAT_I2 corresponds to the I-th element of the  *
  //  ! *               source name array kept in database under lcode         *
  //  ! *               STRNAMES. In general source order in this array        *
  //  ! *               MAY NOT coincide with order of sources in the list     *
  //  ! *               ISTRN_CHR kept in prfil.i  !!                          *
  //  ! *          Bits are counted from 1.                                    *
  //  ! *          1-st bit is set when the source was selected in solution.   *
  //  ! *          2-nd bit reserved for future use. It is always 1.           *
  //  ! *          3-rd bit is set if right ascension of the I-th source       *
  //  ! *                   was estimated in solution.                         *
  //  ! *          4-th bit is set if declination of the I-th source           *
  //  ! *                   was estimated in solution.                         *
  //
  // first bit:
  if (!isAttr(SgVlbiSourceInfo::Attr_NOT_VALID))
    bitArray |= (1<<0);
  // second bit:
  bitArray |= (1<<1);
  // third and fourth bits:
  if (isAttr(Attr_ESTIMATE_COO) && !isAttr(Attr_NOT_VALID))
  {
    bitArray |= (1<<2);
    bitArray |= (1<<3);
  };
  
  return bitArray;
};



//
//
void SgVlbiSourceInfo::applyStatusBits(short bitArray)
{
  // check for deselect flag:
  if (!(bitArray & (1<<0)))
    addAttr(Attr_NOT_VALID);

  // third and fourth bits:
  if (bitArray & (1<<2|1<<3)) // if one of bits is on
    addAttr(Attr_ESTIMATE_COO);
};
