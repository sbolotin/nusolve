#ln -s $path2Origin/${srcL2aDir}/l2aVersion.cpp ${currentDir}/${srcL2aDir}
${cmd} $path2Origin/${srcL2aDir}/l2aVersion.cpp ${currentDir}/${srcL2aDir}
${cmd} $path2Origin/${srcL2aDir}/README ${currentDir}/${srcL2aDir}




