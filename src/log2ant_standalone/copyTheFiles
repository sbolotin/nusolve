path2Origin="../.."
cmd='cp'




sfx="h cpp"
coreNamesSg="SgAttribute SgConstants SgIdentities SgIoExternalFilter SgLogger SgMeteoData SgMJD SgStnLogCollector SgVersion SgVex"
coreNamesL2a="log2ant"

for n in ${coreNamesSg}
do
    for s in ${sfx}
    do
        f="$n.$s"
        echo "copying $f"
#       cp $path2Origin/${srcSgDir}/$f ${currentDir}/${srcSgDir}
#       ln -s $path2Origin/${srcSgDir}/$f ${currentDir}/${srcSgDir}
        ${cmd} $path2Origin/${srcSgDir}/$f ${currentDir}/${srcSgDir}
    done
done

for n in ${coreNamesL2a}
do
    for s in ${sfx}
    do
        f="$n.$s"
        echo "copying $f"
#       cp $path2Origin/${srcL2aDir}/$f ${currentDir}/${srcL2aDir}
#       ln -s $path2Origin/${srcL2aDir}/$f ${currentDir}/${srcL2aDir}
        ${cmd} $path2Origin/${srcL2aDir}/$f ${currentDir}/${srcL2aDir}
    done
done
